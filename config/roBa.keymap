#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 80

// ===== JIS(日本語106/109)配列OS用キーコード =====
#define JP_EXCL  LS(N1)
#define JP_DQT   LS(N2)
#define JP_HASH  LS(N3)
#define JP_DLLR  LS(N4)
#define JP_PERC  LS(N5)
#define JP_AMPR  LS(N6)
#define JP_QUOT  LS(N7)
#define JP_LPAR  LS(N8)
#define JP_RPAR  LS(N9)
#define JP_EQUAL LS(MINUS)
#define JP_CARET EQUAL
#define JP_TILDE LS(EQUAL)
#define JP_AT    LBKT
#define JP_GRAVE LS(LBKT)
#define JP_LBKT  RBKT
#define JP_LBRC  LS(RBKT)
#define JP_RBKT  NUHS
#define JP_RBRC  LS(NUHS)
#define JP_PLUS  LS(SEMI)
#define JP_COLON SQT
#define JP_ASTR  LS(SQT)
#define JP_BSLH  INT1
#define JP_UNDER LS(INT1)
#define JP_YEN   INT3
#define JP_PIPE  LS(INT3)
#define JP_QUES  LS(SLASH)

&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    automouse-layer = <4>;
    scroll-layers = <5>;

    // arrows {
    //     layers = <3>;
    //     bindings =
    //         <&kp RIGHT_ARROW>,
    //         <&kp LEFT_ARROW>,
    //         <&kp UP_ARROW>,
    //         <&kp DOWN_ARROW>;
    //     tick = <10>;
    //     wait-ms = <5>;
    //     tap-ms = <5>;
    // };
};

/ {
    combos {
        compatible = "zmk,combos";

        tab {
            bindings = <&kp TAB>;
            key-positions = <11 12>;
            layers = <0>;
        };

        shift_tab {
            bindings = <&kp LS(TAB)>;
            key-positions = <12 13>;
            layers = <0>;
        };

        eq {
            bindings = <&kp JP_EQUAL>;
            key-positions = <24 25>;
            layers = <0>;
        };

        esc {
            bindings = <&kp ESCAPE>;
            key-positions = <3 4>;
            layers = <0>;
        };

        excel_ins {
            bindings = <&kp LC(KP_PLUS)>;
            key-positions = <18 19>;
            layers = <0>;
        };

        excel_del {
            bindings = <&kp LC(KP_MINUS)>;
            key-positions = <30 31>;
            layers = <0>;
        };

        task_mgr {
            bindings = <&kp LC(LS(ESC))>;
            key-positions = <0 1>;
            layers = <0>;
        };
    };

    macros {
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };
    };

    behaviors {
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        scroll_encoder: scroll_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_UP>, <&msc SCRL_DOWN>;
            tap-ms = <20>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q      &kp W         &kp E         &kp R                           &kp T                                                           &kp Y        &kp U  &kp I      &kp O    &kp P
&kp A      &kp S         &kp D         &kp F                           &kp G        &caps_word                         &kp MINUS       &kp H        &kp J  &kp K      &kp L    &kp JP_COLON
&kp Z      &kp X         &kp C         &kp V                           &kp B        &kp LEFT_SHIFT                     &kp JP_UNDER    &kp N        &kp M  &kp COMMA  &kp DOT  &kp SLASH
&kp LCTRL  &kp LEFT_WIN  &kp LEFT_ALT  &lt_to_layer_0 6 LANG_HIRAGANA  &lt 2 SPACE  &lt_to_layer_0 3 INT_MUHENKAN      &kp BACKSPACE   &lt 1 ENTER                             &lt 5 DEL
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        FUNCTION {
            bindings = <
&trans  &kp N7  &kp N8  &kp N9  &kp KP_DIVIDE                                 &kp F9  &kp F10  &kp F11  &kp F12  &trans
&trans  &kp N4  &kp N5  &kp N6  &kp KP_MULTIPLY  &kp KP_MINUS      &trans  &kp F5  &kp F6   &kp F7   &kp F8   &trans
&trans  &kp N1  &kp N2  &kp N3  &kp KP_PLUS      &kp KP_EQUAL      &trans  &kp F1  &kp F2   &kp F3   &kp F4   &trans
&trans  &kp N0  &kp DOT  &kp KP_ENTER  &trans  &trans      &trans  &trans                            &trans
            >;
        };

        Symbols {
            bindings = <
&kp C_VOL_DN                &kp C_VOL_UP       &kp K_MUTE  &trans       &kp JP_QUOT                                       &kp JP_LPAR  &kp JP_RPAR  &kp JP_LBKT  &kp JP_RBKT  &kp JP_CARET
&kp JP_EXCL                 &kp JP_DQT         &kp JP_HASH &kp JP_DLLR  &kp JP_PERC  &kp LC(LA(KP_NUMBER_0))      &trans  &kp JP_EXCL  &kp JP_AT    &kp JP_HASH  &kp JP_DLLR  &kp JP_COLON
&mt LEFT_SHIFT KP_NUMBER_0  &trans             &trans      &trans       &kp PERIOD   &kp JP_EQUAL                 &trans  &kp FSLH     &kp JP_BSLH  &kp JP_LBRC  &kp JP_RBRC  &kp SEMICOLON
&trans                      &trans             &trans      &trans      &trans       &trans                       &trans  &trans                                                                            &trans
            >;
        };

        ARROW {
            bindings = <
&trans          &kp LC(LS(TAB))         &kp UP_ARROW    &kp LC(TAB)              &trans                            &trans  &trans  &trans  &trans  &trans
&trans          &kp LEFT_ARROW          &kp DOWN_ARROW  &kp RIGHT_ARROW          &trans  &kp ESCAPE      &kp HOME  &trans  &trans  &trans  &trans  &trans
&kp LEFT_SHIFT  &kp LS(LG(LEFT_ARROW))  &trans          &kp LG(LS(RIGHT_ARROW))  &trans  &trans          &kp END   &trans  &trans  &trans  &trans  &trans
&trans          &trans                  &trans          &trans                   &trans  &trans          &trans    &trans                          &trans
            >;

            sensor-bindings = <&inc_dec_kp LC(PAGE_UP) LC(PAGE_DOWN)>;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans    &mkp MB3  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp MB1  &mkp MB2  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp MB4  &mkp MB5  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                              &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &kp HOME  &kp PG_UP    &trans      &trans                          &trans  &trans  &trans  &trans  &trans
&trans  &trans    &kp LCTRL    &kp LSHIFT  &trans  &trans          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &kp END   &kp PG_DN    &trans      &trans  &trans          &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans    &trans       &trans      &trans  &trans          &trans  &trans                          &trans
            >;
        };

        layer_6 {
            bindings = <
&trans  &trans        &trans        &trans        &trans                           &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans  &trans        &trans        &trans        &trans  &trans      &trans       &trans        &trans        &trans        &trans        &trans
&trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &trans  &trans      &bootloader  &trans        &trans        &trans        &trans        &bt BT_CLR
&trans  &trans        &trans        &trans        &trans  &trans      &trans       &trans                                                  &bt BT_CLR_ALL
            >;
        };
    };
};
